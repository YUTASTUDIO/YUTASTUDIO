-- --- TELEPORT WIN FUNCTION ---
local function teleportToGreenPart()
    local _, myRoot, _ = getActiveCharacter()
    if not myRoot then return end
    
    local foundGreenBlock = nil
    
    for _, object in ipairs(Workspace:GetDescendants()) do
        if object:IsA("BasePart") and object.Transparency < 1 and object.CanCollide then
            local c = object.Color
            if (c.G > 0.6 and c.R < 0.4 and c.B < 0.4) or object.BrickColor.Name == "Lime green" or object.BrickColor.Name == "Bright green" then
                if object.Name ~= "YutaStudio_AntiFall" and object.Name ~= "YutaStudio_EvadePlatform" then
                    foundGreenBlock = object
                    break
                end
            end
        end
    end
    
    if foundGreenBlock then
        myRoot.AssemblyLinearVelocity = Vector3.zero
        myRoot.CFrame = CFrame.new(foundGreenBlock.Position + Vector3.new(0, (foundGreenBlock.Size.Y / 2) + 3, 0))
        Library:Notify({
            Title = "TELEPORT SYSTEM",
            Description = "Successfully teleported to safe green zone!",
            Time = 3
        })
    else
        Library:Notify({
            Title = "TELEPORT SYSTEM",
            Description = "No visible green safe blocks found on the map.",
            Time = 3
        })
    end
end


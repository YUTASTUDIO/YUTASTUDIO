                                    for _, p in ipairs(target.Character:GetChildren()) do if p:IsA("BasePart") then firetouchinterest(src, p, 0) task.wait() firetouchinterest(src, p, 1) end end
                                end
                                task.wait(0.02)
                                local _, rRoot, _ = getActiveCharacter() if rRoot then rRoot.CFrame = oldCF end
                                task.wait(0.2)
                            end
                        end
                    end
                end
            end)
        end
    end
end)

local function getServerPlayerNames()
    local names = {}
    for _, p in ipairs(Players:GetPlayers()) do if p ~= LocalPlayer then table.insert(names, p.Name) end end
    return names
end

local antiFallPart, antiFallConnection, antiFallEnabled = nil, nil, false
local function removeAntiFall() if antiFallPart then antiFallPart:Destroy() antiFallPart = nil end if antiFallConnection then antiFallConnection:Disconnect() antiFallConnection = nil end end

local function createAntiFall()
    removeAntiFall() local _, myRoot, _ = getActiveCharacter()
    if not myRoot then task.delay(0.5, function() if antiFallEnabled then createAntiFall() end end) return end
    antiFallPart = Instance.new("Part") antiFallPart.Name = "YutaStudio_AntiFall" antiFallPart.Size = Vector3.new(3000, 2, 3000)
    antiFallPart.Position = Vector3.new(myRoot.Position.X, myRoot.Position.Y - 8, myRoot.Position.Z) antiFallPart.CanCollide = true
    antiFallPart.Transparency = 0.65 antiFallPart.Anchored = true antiFallPart.Parent = Workspace
    antiFallConnection = RunService.Heartbeat:Connect(function()
        local _, r, _ = getActiveCharacter() if r and antiFallPart then antiFallPart.Position = Vector3.new(r.Position.X, antiFallPart.Position.Y, r.Position.Z) end
    end)
    table.insert(ScriptConnections, antiFallConnection)
end

table.insert(ScriptConnections, LocalPlayer.CharacterAdded:Connect(function() task.wait(1) if antiFallEnabled then createAntiFall() end end))

local function teleportToGreenPart()
    local _, myRoot, _ = getActiveCharacter() if not myRoot then return end
    local greenBlock = nil
    for _, obj in ipairs(Workspace:GetDescendants()) do
        if obj:IsA("BasePart") and obj.Transparency < 1 and obj.CanCollide and obj.Name ~= "YutaStudio_AntiFall" and obj.Name ~= "YutaStudio_EvadePlatform" then
            local c = obj.Color
            if (c.G > 0.6 and c.R < 0.4 and c.B < 0.4) or obj.BrickColor.Name == "Lime green" or obj.BrickColor.Name == "Bright green" then greenBlock = obj break end
        end
    end
    if greenBlock then
        myRoot.AssemblyLinearVelocity = Vector3.zero
        myRoot.CFrame = CFrame.new(greenBlock.Position + Vector3.new(0, (greenBlock.Size.Y / 2) + 3, 0))
        Library:Notify({Title = "TELEPORT SYSTEM", Description = "Successfully Finish", Time = 3})
    else
        Library:Notify({Title = "TELEPORT SYSTEM", Description = "NOT FOUND.", Time = 3})
    end
end


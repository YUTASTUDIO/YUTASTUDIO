local function findUniversalBomb()
    local myChar, _, _ = getActiveCharacter()
    if not myChar then return nil, nil end
    for _, child in ipairs(myChar:GetChildren()) do
        if child:IsA("Tool") and (string.find(string.lower(child.Name), "bomb") or string.find(string.lower(child.Name), "pass") or string.find(string.lower(child.Name), "tag")) then return child, "Tool" end
    end
    for _, child in ipairs(myChar:GetDescendants()) do
        if (child:IsA("BasePart") or child:IsA("Model")) and (string.find(string.lower(child.Name), "bomb") or string.find(string.lower(child.Name), "explosive")) then return child, "WeldModel" end
    end
    local bp = LocalPlayer:FindFirstChildOfClass("Backpack")
    if bp then
        for _, child in ipairs(bp:GetChildren()) do
            if child:IsA("Tool") and (string.find(string.lower(child.Name), "bomb") or string.find(string.lower(child.Name), "pass") or string.find(string.lower(child.Name), "tag")) then return child, "BackpackTool" end
        end
    end
    return nil, nil
end

local function forceTransferBomb()
    local bomb, bombType = findUniversalBomb()
    if not bomb or not bomb.Parent then return end
    local myChar, myRoot, myHum = getActiveCharacter()
    if not (myRoot and myHum and myHum.Health > 0) then return end
    local target = getClosestPlayer()
    if not target or not target.Character then return end

    local targetRoot = target.Character:FindFirstChild("HumanoidRootPart")
    local targetHum = target.Character:FindFirstChild("Humanoid")

    if targetRoot and targetHum and targetHum.Health > 0 and targetHum:GetState() ~= Enum.HumanoidStateType.Dead then
        local originalCFrame = myRoot.CFrame
        if bombType == "BackpackTool" then
            myHum:EquipTool(bomb)
            task.wait(0.03)
        end
        myChar, myRoot, myHum = getActiveCharacter()
        if myRoot and myHum and myHum.Health > 0 and bomb and bomb.Parent then
            safeTeleport(targetRoot, CFrame.new(0, 0, 0))
            task.wait(0.05)
            if firetouchinterest then
                local touchSource = bomb:FindFirstChild("Handle") or bomb:FindFirstChildOfClass("BasePart") or myRoot
                if touchSource then
                    for _, part in ipairs(target.Character:GetChildren()) do
                        if part:IsA("BasePart") then
                            firetouchinterest(touchSource, part, 0)
                            task.wait()
                            firetouchinterest(touchSource, part, 1)
                        end
                    end
                end
            end
            local _, refreshedRoot, _ = getActiveCharacter()
            if refreshedRoot then
                refreshedRoot.CFrame = originalCFrame
            end
        end
    end
end


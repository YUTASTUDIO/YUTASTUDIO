getgenv().YutaStudio_Cleanup = function()
    fakeLagActive = false
    fpsBoosterActive = false
    antiPassActive = false
    espActive = false

    for _, connection in ipairs(ScriptConnections) do
        if connection and connection.Disconnect then
            pcall(function() connection:Disconnect() end)
        end
    end
    table.clear(ScriptConnections)

    pcall(removeAntiFall)
    pcall(removeEvadePlatform)
    pcall(clearAllESP)
    pcall(restoreGameGraphics)

    pcall(function()
        local _, _, hum = getActiveCharacter()
        if hum then
            hum.WalkSpeed = 16
            hum.JumpPower = 50
            hum.JumpHeight = 7.2
        end
    end)
    
    for _, child in ipairs(CoreGui:GetChildren()) do
        if child.Name == UI_SCREEN_NAME then
            pcall(function() child:Destroy() end)
        end
    end
end

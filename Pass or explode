local function getActiveCharacter()
    local char = LocalPlayer.Character
    if not char then return nil end
    local root = char:FindFirstChild("HumanoidRootPart")
    local hum = char:FindFirstChildOfClass("Humanoid")
    if root and hum and hum.Health > 0 and hum:GetState() ~= Enum.HumanoidStateType.Dead then
        return char, root, hum
    end
    return nil
end

local function safeTeleport(targetPart, offset)
    local _, myRoot, _ = getActiveCharacter()
    if not myRoot or not targetPart then return end
    offset = offset or CFrame.new(0, 0, 0)
    myRoot.AssemblyLinearVelocity = Vector3.zero
    myRoot.AssemblyAngularVelocity = Vector3.zero
    myRoot.CFrame = targetPart.CFrame * offset
    RunService.Heartbeat:Wait()
    _, myRoot, _ = getActiveCharacter()
    if myRoot then
        myRoot.AssemblyLinearVelocity = Vector3.zero
        myRoot.AssemblyAngularVelocity = Vector3.zero
    end
end

local function isNearSpawn(position)
    for _, obj in ipairs(Workspace:GetDescendants()) do
        if obj:IsA("SpawnLocation") and (position - obj.Position).Magnitude < 15 then return true end
    end
    local lobby = Workspace:FindFirstChild("Lobby") or Workspace:FindFirstChild("Spawn") or Workspace:FindFirstChild("SpawnArea")
    if lobby then
        if lobby:IsA("BasePart") and (position - lobby.Position).Magnitude < 25 then return true
        elseif lobby:IsA("Model") then
            local primary = lobby.PrimaryPart or lobby:FindFirstChildOfClass("BasePart")
            if primary and (position - primary.Position).Magnitude < 25 then return true end
        end
    end
    return false
end

local function getClosestPlayer()
    local closestPlayer = nil
    local shortestDistance = math.huge
    local _, myRoot, _ = getActiveCharacter()
    if not myRoot then return nil end
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character and player.Character:IsDescendantOf(Workspace) then
            local targetRoot = player.Character:FindFirstChild("HumanoidRootPart")
            local targetHum = player.Character:FindFirstChildOfClass("Humanoid")
            if targetRoot and targetHum and targetHum.Health > 0 and targetHum:GetState() ~= Enum.HumanoidStateType.Dead then
                if not player.Character:FindFirstChildOfClass("ForceField") and not isNearSpawn(targetRoot.Position) then
                    local dist = (myRoot.Position - targetRoot.Position).Magnitude
                    if dist < shortestDistance then
                        shortestDistance = dist
                        closestPlayer = player
                    end
                end
            end
        end
    end
    return closestPlayer
end


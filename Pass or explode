local function findUniversalBomb()
    local myChar = getActiveCharacter() if not myChar then return nil, nil end
    for _, c in ipairs(myChar:GetChildren()) do if c:IsA("Tool") and (string.find(string.lower(c.Name), "bomb") or string.find(string.lower(c.Name), "pass")) then return c, "Tool" end end
    for _, c in ipairs(myChar:GetDescendants()) do if (c:IsA("BasePart") or c:IsA("Model")) and (string.find(string.lower(c.Name), "bomb") or string.find(string.lower(c.Name), "explosive")) then return c, "WeldModel" end end
    local bp = LocalPlayer:FindFirstChildOfClass("Backpack")
    if bp then for _, c in ipairs(bp:GetChildren()) do if c:IsA("Tool") and (string.find(string.lower(c.Name), "bomb") or string.find(string.lower(c.Name), "pass")) then return c, "BackpackTool" end end end
    return nil, nil
end

local function forceTransferBomb()
    local bomb, bType = findUniversalBomb() if not bomb or not bomb.Parent then return end
    local _, myRoot, myHum = getActiveCharacter() if not myRoot then return end
    local target = getClosestPlayer() if not target or not target.Character then return end
    local tRoot = target.Character:FindFirstChild("HumanoidRootPart")
    if tRoot and target.Character.Humanoid.Health > 0 then
        local oldCF = myRoot.CFrame
        if bType == "BackpackTool" then myHum:EquipTool(bomb) task.wait(0.03) end
        if myRoot and bomb.Parent then
            safeTeleport(tRoot) task.wait(0.05)
            if firetouchinterest then
                local src = bomb:FindFirstChild("Handle") or bomb:FindFirstChildOfClass("BasePart") or myRoot
                for _, p in ipairs(target.Character:GetChildren()) do if p:IsA("BasePart") then firetouchinterest(src, p, 0) task.wait() firetouchinterest(src, p, 1) end end
            end
            local _, rRoot, _ = getActiveCharacter() if rRoot then rRoot.CFrame = oldCF end
        end
    end
end


local IMAGE_URL = "https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcRq6yriKDq5GUQFmca2BXbXJsM5Zmo0o18xYMU4-UihcQ&s=10"
local FILE_NAME = "loader_bg.png"
local backgroundImageId = ""

-- Attempt to download and use the external web image via executor functions
local success, err = pcall(function()
    if not isfile(FILE_NAME) then
        writefile(FILE_NAME, game:HttpGet(IMAGE_URL))
    end
    backgroundImageId = getcustomasset(FILE_NAME)
end)

-- Fallback default background color if the image download fails
if not success or backgroundImageId == "" then
    warn("Could not load external image, using default background color: " .. tostring(err))
end

-- --- SPAWN ZONE DETECTOR ---
local function isNearSpawn(position)
    for _, obj in ipairs(Workspace:GetDescendants()) do
        if obj:IsA("SpawnLocation") then
            if (position - obj.Position).Magnitude < 15 then
                return true
            end
        end
    end
    
    local lobby = Workspace:FindFirstChild("Lobby") or Workspace:FindFirstChild("Spawn") or Workspace:FindFirstChild("SpawnArea")
    if lobby then
        if lobby:IsA("BasePart") then
            if (position - lobby.Position).Magnitude < 25 then
                return true
            end
        elseif lobby:IsA("Model") then
            local primary = lobby.PrimaryPart or lobby:FindFirstChildOfClass("BasePart")
            if primary and (position - primary.Position).Magnitude < 25 then
                return true
            end
        end
    end
    
    return false
end


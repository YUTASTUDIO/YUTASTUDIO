-- --- ANTI-FALL BARRIER ---
local antiFallPart = nil
local antiFallConnection = nil
local antiFallEnabled = false

local function removeAntiFall()
    if antiFallPart then antiFallPart:Destroy() antiFallPart = nil end
    if antiFallConnection then antiFallConnection:Disconnect() antiFallConnection = nil end
end

local function createAntiFall()
    removeAntiFall()
    local _, myRoot, _ = getActiveCharacter()
    if not myRoot then 
        task.delay(0.5, function() if antiFallEnabled then createAntiFall() end end)
        return 
    end
    antiFallPart = Instance.new("Part")
    antiFallPart.Name = "YutaStudio_AntiFall"
    antiFallPart.Size = Vector3.new(3000, 2, 3000)
    antiFallPart.Position = Vector3.new(myRoot.Position.X, myRoot.Position.Y - 12, myRoot.Position.Z)
    antiFallPart.CanCollide = true
    antiFallPart.Transparency = 0.1
    antiFallPart.Color = Color3.fromRGB(0, 255, 100)
    antiFallPart.Material = Enum.Material.Neon
    antiFallPart.Anchored = true
    antiFallPart.Parent = Workspace
    
    antiFallConnection = RunService.Heartbeat:Connect(function()
        local _, activeRoot, _ = getActiveCharacter()
        if activeRoot and antiFallPart then
            antiFallPart.Position = Vector3.new(activeRoot.Position.X, antiFallPart.Position.Y, activeRoot.Position.Z)
        end
    end)
end

LocalPlayer.CharacterAdded:Connect(function()
    task.wait(1)
    if antiFallEnabled then createAntiFall() end
end)


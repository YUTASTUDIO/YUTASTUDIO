-- --- BOMB CHECKER ---
local function playerHasBomb(player)
    local char = player.Character
    if not char then return false end
    for _, child in ipairs(char:GetChildren()) do
        if child:IsA("Tool") and (string.find(string.lower(child.Name), "bomb") or string.find(string.lower(child.Name), "pass") or string.find(string.lower(child.Name), "tag")) then return true end
    end
    local bp = player:FindFirstChild("Backpack")
    if bp then
        for _, child in ipairs(bp:GetChildren()) do
            if child:IsA("Tool") and (string.find(string.lower(child.Name), "bomb") or string.find(string.lower(child.Name), "pass") or string.find(string.lower(child.Name), "tag")) then return true end
        end
    end
    for _, child in ipairs(char:GetDescendants()) do
        if (child:IsA("BasePart") or child:IsA("Model")) and (string.find(string.lower(child.Name), "bomb") or string.find(string.lower(child.Name), "explosive")) then return true end
    end
    return false
end


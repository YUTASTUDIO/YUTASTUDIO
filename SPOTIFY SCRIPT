-- Robust Executor HTTP Request Extraction (Guarantees support on ANY executor)
local requestFunction = request or http_request or (http and http.request) or (syn and syn.request) or (fluxus and fluxus.request)

local function httpGet(url)
    local success, result = pcall(function()
        return game:HttpGet(url)
    end)
    if success and result then return result end
    
    if requestFunction then
        local reqSuccess, response = pcall(function()
            return requestFunction({Url = url, Method = "GET"})
        end)
        if reqSuccess and response and response.Body then
            return response.Body
        end
    end
    return nil
end


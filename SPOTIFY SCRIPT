local function updateRealtimeActiveUsers()
    local myUserId = tostring(localPlayer.UserId)
    local myUsername = localPlayer.Name
    
    local payload = HttpService:JSONEncode({
        username = myUsername,
        last_seen = os.time()
    })
    
    task.spawn(function()
        if requestFunction then
            pcall(function()
                requestFunction({
                    Url = string.format("%s/%s.json", DATABASE_URL, myUserId),
                    Method = "PUT",
                    Headers = {["Content-Type"] = "application/json"},
                    Body = payload
                })
            end)
        end
    end)

    task.spawn(function()
        if requestFunction then
            local success, response = pcall(function()
                return requestFunction({
                    Url = DATABASE_URL .. ".json",
                    Method = "GET"
                })
            end)
            
            if success and response and response.Body then
                local decodeSuccess, data = pcall(function() return HttpService:JSONDecode(response.Body) end)
                if decodeSuccess and type(data) == "table" then
                    local activeCount = 0
                    local now = os.time()
             
                    for key, userSession in pairs(data) do
                        if type(userSession) == "table" and userSession.last_seen then
                            if now - userSession.last_seen < 90 then
                                activeCount = activeCount + 1
                            else
                                task.spawn(pcall, function()
                                    requestFunction({
                                        Url = string.format("%s/%s.json", DATABASE_URL, key),
                                        Method = "DELETE"
                                    })
                                end)
                            end
                        end
                    end
                    
                    ActiveBadge.Text = string.format("🟢 Active: %d", math.max(1, activeCount))
                    return
                end
            end
        end
        ActiveBadge.Text = "🟢 Active: 1 (Local)"
    end)
end


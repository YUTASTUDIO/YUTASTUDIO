-- Loading Visual Transitions Thread
task.spawn(function()
    local phases = {
        {progress = 0.15, desc = "Verifying client details..."},
        {progress = 0.35, desc = "Preparing executor environment..."},
        {progress = 0.55, desc = "Clearing heavy textures..."},
        {progress = 0.75, desc = "Configuring low-end optimizations..."},
        {progress = 0.90, desc = "Connecting dynamic UI layers..."},
        {progress = 1.00, desc = "Launching Dashboard!"}
    }

    local progressTweenTime = 0.35
    for _, phase in ipairs(phases) do
        Status.Text = phase.desc
        local tweenInfo = TweenInfo.new(progressTweenTime, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
        local fillTween = TweenService:Create(ProgressFill, tweenInfo, {Size = UDim2.new(phase.progress, 0, 1, 0)})
        fillTween:Play()
        fillTween.Completed:Wait()
        task.wait(0.2)
    end

    -- Clean Fade-out UI Elements
    local fadeTweenInfo = TweenInfo.new(0.4, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
    
    local cardFade = TweenService:Create(LoadingCard, fadeTweenInfo, {BackgroundTransparency = 1})
    local strokeFade = TweenService:Create(CardStroke, fadeTweenInfo, {Transparency = 1})
    local text1Fade = TweenService:Create(Title, fadeTweenInfo, {TextTransparency = 1})
    local text2Fade = TweenService:Create(Status, fadeTweenInfo, {TextTransparency = 1})
    local text3Fade = TweenService:Create(VersionText, fadeTweenInfo, {TextTransparency = 1})
    local progressBgFade = TweenService:Create(ProgressBg, fadeTweenInfo, {BackgroundTransparency = 1})
    local progressFillFade = TweenService:Create(ProgressFill, fadeTweenInfo, {BackgroundTransparency = 1})

    cardFade:Play()
    strokeFade:Play()
    text1Fade:Play()
    text2Fade:Play()
    text3Fade:Play()
    progressBgFade:Play()
    progressFillFade:Play()
    
    task.wait(0.4)
    
    local mainBackgroundFade = TweenService:Create(LoadingFrame, TweenInfo.new(0.5, Enum.EasingStyle.Quad), {BackgroundTransparency = 1})
    mainBackgroundFade:Play()
    mainBackgroundFade.Completed:Connect(function()
        LoadingFrame:Destroy()
        MainFrame.Visible = true
        ToggleButton.Visible = true
        
        -- Smooth Dashboard Entrance Transition
        MainFrame.Size = UDim2.new(0, 0, 0, 0)
        local scaleIn = TweenService:Create(MainFrame, TweenInfo.new(0.6, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
            Size = UDim2.new(0, 785, 0, 410)
        })
        scaleIn:Play()
    end)
end)

----------------------------------------------------
-- REVERSIBLE FPS SPEED UTILITY
----------------------------------------------------
local fpsBoostActive = false
local originalGraphicsCache = {}
local dynamicAssetConnection = nil

local function optimizeInstance(obj)
    if not obj or not obj.Parent then return end
    if obj:IsA("Part") or obj:IsA("MeshPart") or obj:IsA("UnionOperation") then
        if not originalGraphicsCache[obj] then
            originalGraphicsCache[obj] = {Material = obj.Material, CastShadow = obj.CastShadow}
        end
        pcall(function()
            obj.Material = Enum.Material.SmoothPlastic
            obj.CastShadow = false
        end)
    elseif obj:IsA("Decal") or obj:IsA("Texture") then
        if not originalGraphicsCache[obj] then
            originalGraphicsCache[obj] = {Transparency = obj.Transparency}
        end
        pcall(function() obj.Transparency = 1 end)
    elseif obj:IsA("ParticleEmitter") or obj:IsA("Trail") or obj:IsA("Beam") or obj:IsA("Fire") or obj:IsA("Sparkles") then
        if not originalGraphicsCache[obj] then
            originalGraphicsCache[obj] = {Enabled = obj.Enabled}
        end
        pcall(function() obj.Enabled = false end)
    end
end

local function toggleFpsBooster()
    fpsBoostActive = not fpsBoostActive
    if fpsBoostActive then
        originalGraphicsCache.GlobalShadows = Lighting.GlobalShadows
        pcall(function() Lighting.GlobalShadows = false end)
        for _, object in ipairs(workspace:GetDescendants()) do
            optimizeInstance(object)
        end
        dynamicAssetConnection = workspace.DescendantAdded:Connect(function(newObject)
            if fpsBoostActive then optimizeInstance(newObject) end
        end)
        FpsButton.BackgroundColor3 = Color3.fromRGB(30, 215, 96)
        FpsButton.TextColor3 = Color3.fromRGB(0, 0, 0)
    else
        if dynamicAssetConnection then
            dynamicAssetConnection:Disconnect()
            dynamicAssetConnection = nil
        end
        if originalGraphicsCache.GlobalShadows ~= nil then
            pcall(function() Lighting.GlobalShadows = originalGraphicsCache.GlobalShadows end)
        end
        for targetObj, properties in pairs(originalGraphicsCache) do
            if targetObj ~= "GlobalShadows" and typeof(targetObj) == "Instance" and targetObj.Parent then
                pcall(function()
                    for propertyName, originalValue in pairs(properties) do
                        targetObj[propertyName] = originalValue
                    end
                end)
            end
        end
        originalGraphicsCache = {}
        FpsButton.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
        FpsButton.TextColor3 = Color3.fromRGB(255, 255, 255)
    end
end

FpsButton.MouseButton1Click:Connect(toggleFpsBooster)


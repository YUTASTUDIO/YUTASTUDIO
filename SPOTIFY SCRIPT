-- WEBHOOK FEEDBACK SUBMISSION LOGIC
----------------------------------------------------
SendFeedbackBtn.MouseButton1Click:Connect(function()
    local feedbackText = FeedbackInput.Text
    if feedbackText == "" or feedbackText == "Type your ideas, bugs, or feedback here..." then
        SendFeedbackBtn.Text = "CANNOT SEND EMPTY MESSAGE!"
        SendFeedbackBtn.BackgroundColor3 = Color3.fromRGB(215, 30, 30)
        task.wait(2)
        SendFeedbackBtn.Text = "SUBMIT FEEDBACK"
        SendFeedbackBtn.BackgroundColor3 = Color3.fromRGB(30, 215, 96)
        return
    end

    SendFeedbackBtn.Text = "SENDING..."
    SendFeedbackBtn.Active = false

    local data = {
        ["embeds"] = {{
            ["title"] = "📩 New Script Feedback received!",
            ["description"] = "**Message:**\n" .. feedbackText,
            ["color"] = 2021664,
            ["fields"] = {
                {["name"] = "User Name", ["value"] = localPlayer.Name, ["inline"] = true},
                {["name"] = "User ID", ["value"] = tostring(localPlayer.UserId), ["inline"] = true},
                {["name"] = "Game Info", ["value"] = game:GetService("MarketplaceService"):GetProductInfo(game.PlaceId).Name .. " (" .. tostring(game.PlaceId) .. ")", ["inline"] = false}
            },
            ["footer"] = {["text"] = "Roblox Spotify Script Monitor | DEVELOPER: YUTASTUDIO"}
        }}
    }

    local jsonData = HttpService:JSONEncode(data)

    if requestFunction then
        local success, err = pcall(function()
            requestFunction({
                Url = getgenv().FeedbackWebhook,
                Method = "POST",
                Headers = {["Content-Type"] = "application/json"},
                Body = jsonData
            })
        end)

        if success then
            SendFeedbackBtn.Text = "FEEDBACK SENT! THANK YOU"
            SendFeedbackBtn.BackgroundColor3 = Color3.fromRGB(30, 215, 96)
            FeedbackInput.Text = ""
        else
            SendFeedbackBtn.Text = "TRANSMISSION ERROR!"
            SendFeedbackBtn.BackgroundColor3 = Color3.fromRGB(215, 30, 30)
            warn("Feedback sending error: " .. tostring(err))
        end
    else
        SendFeedbackBtn.Text = "EXECUTOR MISSING HTTP REQ!"
        SendFeedbackBtn.BackgroundColor3 = Color3.fromRGB(215, 30, 30)
    end

    task.wait(2)
    SendFeedbackBtn.Text = "SUBMIT FEEDBACK"
    SendFeedbackBtn.BackgroundColor3 = Color3.fromRGB(30, 215, 96)
    SendFeedbackBtn.Active = true
end)

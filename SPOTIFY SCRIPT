-- DYNAMIC VISUAL REFRESH ENGINE (FIXES STUCK HOVER BUG)
----------------------------------------------------
local function updateButtonVisuals(button, isHovered)
    local baseColor = Color3.fromRGB(40, 40, 40)
    
    if button.Name == "PlayButton" or button.Name == "SaveAudioBtn" or button.Name == "SendFeedbackBtn" then
        baseColor = Color3.fromRGB(30, 215, 96)
    elseif button.Name == "VolButton" then
        baseColor = Color3.fromRGB(30, 30, 30)
    elseif button.Name == "JoinDiscordBtn" then
        baseColor = Color3.fromRGB(88, 101, 242)
    elseif button.Name == "ShaderButton" or button.Name == "FpsButton" or button.Name == "BrightButton" or button.Name == "ParticlesButton" then
        if button.TextColor3 == Color3.fromRGB(0, 0, 0) then
            baseColor = Color3.fromRGB(30, 215, 96)
        else
            baseColor = Color3.fromRGB(40, 40, 40)
        end
    elseif button:GetAttribute("OriginalBg") then
        baseColor = button:GetAttribute("OriginalBg")
    else
        baseColor = button.BackgroundColor3
    end

    local targetBg = baseColor
    if isHovered then
        if baseColor == Color3.fromRGB(30, 215, 96) then
            targetBg = Color3.fromRGB(45, 245, 115)
        else
            targetBg = baseColor:Lerp(Color3.fromRGB(255, 255, 255), 0.12)
        end
    end
    
    local tweenFast = TweenInfo.new(0.1, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
    TweenService:Create(button, tweenFast, {BackgroundColor3 = targetBg}):Play()
end

----------------------------------------------------
-- PREMIUM INTERACTION SYSTEM & TRANSITIONS
----------------------------------------------------
local function registerButtonEffects(button)
    if not button:IsA("GuiButton") then return end
    if not button:GetAttribute("OriginalBg") then
        button:SetAttribute("OriginalBg", button.BackgroundColor3)
    end
    
    local uiScale = button:FindFirstChildOfClass("UIScale") or Instance.new("UIScale")
    uiScale.Scale = 1
    uiScale.Parent = button
    
    local hoverStroke = button:FindFirstChildOfClass("UIStroke") or Instance.new("UIStroke")
    hoverStroke.Thickness = 1.5
    hoverStroke.Color = Color3.fromRGB(30, 215, 96)
    hoverStroke.Transparency = 1 -- Hidden by default
    hoverStroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    hoverStroke.Parent = button

    if button.BackgroundColor3 == Color3.fromRGB(30, 215, 96) then
        hoverStroke.Color = Color3.fromRGB(255, 255, 255)
    end
    
    local isHovered = false
    local tweenFast = TweenInfo.new(0.1, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
    local tweenBounce = TweenInfo.new(0.3, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
    
    button.MouseEnter:Connect(function()
        isHovered = true
        TweenService:Create(uiScale, tweenBounce, {Scale = 1.04}):Play()
        updateButtonVisuals(button, true)
        TweenService:Create(hoverStroke, tweenFast, {Transparency = 0.4}):Play()
    end)
    
    button.MouseLeave:Connect(function()
        isHovered = false
        TweenService:Create(uiScale, tweenBounce, {Scale = 1.00}):Play()
        updateButtonVisuals(button, false)
        TweenService:Create(hoverStroke, tweenFast, {Transparency = 1.0}):Play()
    end)
    
    button.MouseButton1Down:Connect(function()
        pcall(function() 
            SoundService:PlayLocalSound(MCClickSound) 
        end)
        TweenService:Create(uiScale, tweenFast, {Scale = 0.94}):Play()
    end)
    
    button.MouseButton1Up:Connect(function()
        local targetScale = isHovered and 1.04 or 1.00
        TweenService:Create(uiScale, tweenBounce, {Scale = targetScale}):Play()
    end)
end


setCustomAsset = function(button, name, url, fallbackId)
    local assetApplied = false
    local getAsset = getcustomasset or getsynasset
    
    local success, hasFileSystem = pcall(function() return writefile ~= nil and isfile ~= nil and getAsset ~= nil end)
    if success and hasFileSystem then
        local fileExists = false
        pcall(function() fileExists = isfile(name) end)
        if not fileExists then
            local data = httpGet(url)
            if data then pcall(function() writefile(name, data) end) end
        end
        local loadOk, asset = pcall(function() return getAsset(name) end)
        if loadOk and asset then
            button.Image = asset
            assetApplied = true
        end
    end
    if not assetApplied then
        button.Image = fallbackId
        button.ImageColor3 = Color3.fromRGB(30, 215, 96)
    end
end


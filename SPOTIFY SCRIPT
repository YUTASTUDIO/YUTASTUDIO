                Headers = {["Content-Type"] = "application/json"},
                Body = HttpService:JSONEncode({
                    embeds = {{
                        title = "📩 New Script Feedback received!",
                        description = "**Message:**\n" .. feedbackText,
                        color = 2021664,
                        fields = {
                            {name = "User Name", value = localPlayer.Name, inline = true},
                            {name = "User ID", value = tostring(localPlayer.UserId), inline = true},
                            {name = "Game Info", value = game:GetService("MarketplaceService"):GetProductInfo(game.PlaceId).Name .. " (" .. tostring(game.PlaceId) .. ")", inline = false}
                        }
                    }}
                })
            })
        end)
        if success then
            SendFeedbackBtn.Text = "SENT! THANK YOU"
            FeedbackInput.Text = ""
        else
            SendFeedbackBtn.Text = "TRANSMISSION ERROR!"
        end
    else
        SendFeedbackBtn.Text = "EXECUTOR MISSING HTTP REQ!"
    end
    task.wait(2)
    SendFeedbackBtn.Text = "SUBMIT FEEDBACK"
    SendFeedbackBtn.BackgroundColor3 = Color3.fromRGB(30, 215, 96)
    SendFeedbackBtn.Active = true
end)

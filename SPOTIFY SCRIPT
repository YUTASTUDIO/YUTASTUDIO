-- Live Time Tracking Progress Bar Loop
task.spawn(function()
    while task.wait(0.5) do
        if not MainFrame or not MainFrame.Parent then break end
        if Sound.IsPlaying and Sound.TimeLength > 0 then
            local percent = Sound.TimePosition / Sound.TimeLength
            ProgressBarFill.Size = UDim2.new(percent, 0, 1, 0)
            local currentMin, currentSec = math.floor(Sound.TimePosition / 60), math.floor(Sound.TimePosition % 60)
            local totalMin, totalSec = math.floor(Sound.TimeLength / 60), math.floor(Sound.TimeLength % 60)
            SongInfo.Text = string.format("Time: %02d:%02d / %02d:%02d", currentMin, currentSec, totalMin, totalSec)
        end
    end
end)


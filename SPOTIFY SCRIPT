local potatoActive = false
local originalGraphicsCache = {}
local dynamicAssetConnection

local function applyPotatoSettings(obj)
    if obj:IsA("Part") or obj:IsA("MeshPart") or obj:IsA("UnionOperation") then
        if not originalGraphicsCache[obj] then
            originalGraphicsCache[obj] = {
                Material = obj.Material, 
                CastShadow = obj.CastShadow,
                Reflectance = obj.Reflectance
            }
        end
        pcall(function()
            obj.Material = Enum.Material.SmoothPlastic
            obj.CastShadow = false
            obj.Reflectance = 0
        end)
    elseif obj:IsA("Decal") or obj:IsA("Texture") then
        if not originalGraphicsCache[obj] then
            originalGraphicsCache[obj] = {Transparency = obj.Transparency}
        end
        pcall(function() obj.Transparency = 1 end)
    end
end

local function togglePotatoGraphics()
    potatoActive = not potatoActive
    if potatoActive then
        pcall(function()
            settings().Rendering.QualityLevel = Enum.QualityLevel.Level01
            Lighting.GlobalShadows = false
            workspace.LevelOfDetail = Enum.ModelLevelOfDetail.Disabled
        end)

        local descendants = workspace:GetDescendants()
        local count = 0
        for _, object in ipairs(descendants) do
            applyPotatoSettings(object)
            count = count + 1
            if count % 200 == 0 then task.wait() end
        end

        dynamicAssetConnection = workspace.DescendantAdded:Connect(function(newObject)
            if getgenv().SpotifyCurrentExecutionID ~= UniqueExecutionID then
                if dynamicAssetConnection then
                    dynamicAssetConnection:Disconnect()
                    dynamicAssetConnection = nil
                end
                return
            end
            if potatoActive then applyPotatoSettings(newObject) end
        end)

        PotatoButton.Text = "POTATO: ON"
        PotatoButton.BackgroundColor3 = Color3.fromRGB(30, 215, 96)
        PotatoButton.TextColor3 = Color3.fromRGB(0, 0, 0)
    else
        pcall(function()
            settings().Rendering.QualityLevel = Enum.QualityLevel.Automatic
            Lighting.GlobalShadows = true
        end)

        if dynamicAssetConnection then
            dynamicAssetConnection:Disconnect()
            dynamicAssetConnection = nil
        end

        for targetObj, properties in pairs(originalGraphicsCache) do
            if typeof(targetObj) == "Instance" and targetObj.Parent then
                pcall(function()
                    for propertyName, originalValue in pairs(properties) do
                        targetObj[propertyName] = originalValue
                    end
                end)
            end
        end
        originalGraphicsCache = {}

        PotatoButton.Text = "POTATO: OFF"
        PotatoButton.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
        PotatoButton.TextColor3 = Color3.fromRGB(255, 255, 255)
    end
    updateButtonVisuals(PotatoButton, true)
end


ToggleButton.MouseButton1Click:Connect(function()
    MainFrame.Visible = not MainFrame.Visible
    ToggleStroke.Color = MainFrame.Visible and Color3.fromRGB(30, 215, 96) or Color3.fromRGB(80, 80, 80)

-- PLAYLIST PERSISTENCE DATA STORAGE (SAFE IO)
----------------------------------------------------
local playlistFileName = "spotify_script_playlist.json"
local savedSongs = {}

local function safeIsFile(file)
    local success, result = pcall(function() return isfile and isfile(file) end)
    return success and result
end

local function safeReadFile(file)
    local success, result = pcall(function() return readfile and readfile(file) end)
    return success and result or nil
end

local function safeWriteFile(file, content)
    pcall(function() if writefile then writefile(file, content) end end)
end

local function loadPlaylistData()
    if safeIsFile(playlistFileName) then
        local content = safeReadFile(playlistFileName)
        if content then
            local decodeSuccess, decodedTable = pcall(function() return HttpService:JSONDecode(content) end)
            if decodeSuccess and type(decodedTable) == "table" then
                savedSongs = decodedTable
            end
        end
    end
end

local function savePlaylistData()
    pcall(function() safeWriteFile(playlistFileName, HttpService:JSONEncode(savedSongs)) end)
end


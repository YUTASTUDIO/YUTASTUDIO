-- Play Button Logic
PlayButton.MouseButton1Click:Connect(function()
    local id = tonumber(SongInput.Text:match("%d+"))
    if id then
        Sound.SoundId = "rbxassetid://" .. id
        Sound:Play()
        SongInfo.Text = "Playing ID: " .. id
    else
        SongInfo.Text = "Error: Invalid ID String"
    end
end)

-- Pause/Resume Logic
PauseButton.MouseButton1Click:Connect(function()
    if Sound.IsPlaying then
        Sound:Pause()
        PauseButton.Text = "RESUME"
    elseif Sound.IsLoaded and not Sound.IsPlaying then
        Sound:Resume()
        PauseButton.Text = "PAUSE"
    end
end)

-- Volume Controls
local currentVol = 50
VolButton.MouseButton1Click:Connect(function()
    currentVol = currentVol + 25
    if currentVol > 100 then currentVol = 0 end
    Sound.Volume = currentVol / 100
    VolButton.Text = "VOL: " .. currentVol .. "%"
end)


local Sound = workspace:FindFirstChild("RobloxSpotifySound") or Instance.new("Sound", workspace)
Sound.Name = "RobloxSpotifySound"
Sound.Volume = 0.5

local function startAudioEngine(rawAudioId)
    if not rawAudioId then 
        SongInfo.Text = "Error: Void ID input"
        return 
    end
    
    -- Anti-Bug: Extract numbers only if user inputs strings or full links
    local cleanId = tostring(rawAudioId):match("%d+")
    if cleanId then
        pcall(function()
            Sound.SoundId = "rbxassetid://" .. cleanId
            Sound:Play()
        end)
        SongInfo.Text = "Playing ID: " .. cleanId
        SongInput.Text = cleanId
        PauseButton.Text = "PAUSE"
    else
        SongInfo.Text = "Error: Invalid Audio Input Token!"
    end
end

PlayButton.MouseButton1Click:Connect(function()
    startAudioEngine(SongInput.Text)
end)


local playlistFileName = "spotify_script_playlist.json"
local savedSongs = {}

local function loadPlaylistData()
    if isfile and readfile and isfile(playlistFileName) then
        local success, content = pcall(function() return readfile(playlistFileName) end)
        if success and content then
            local decodeSuccess, decodedTable = pcall(function() return HttpService:JSONDecode(content) end)
            if decodeSuccess and type(decodedTable) == "table" then
                savedSongs = decodedTable
            end
        end
    end
end

local function savePlaylistData()
    if writefile then
        pcall(function()
            writefile(playlistFileName, HttpService:JSONEncode(savedSongs))
        end)
    end
end


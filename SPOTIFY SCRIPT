local effectsEnabled = true
local originalEffectsCache = {}
local dynamicEffectsConnection

local function stripEffects(obj)
    -- Visual workspace emitters
    if obj:IsA("ParticleEmitter") or obj:IsA("Trail") or obj:IsA("Beam") or 
       obj:IsA("Fire") or obj:IsA("Sparkles") or obj:IsA("Smoke") then
        if not originalEffectsCache[obj] then
            originalEffectsCache[obj] = {Enabled = obj.Enabled}
        end
        pcall(function() obj.Enabled = false end)
    -- Global screen post-processing elements
    elseif obj:IsA("PostEffect") or obj:IsA("BloomEffect") or obj:IsA("BlurEffect") or 
           obj:IsA("ColorCorrectionEffect") or obj:IsA("SunRaysEffect") or 
           obj:IsA("DepthOfFieldEffect") or obj:IsA("Atmosphere") or obj:IsA("Clouds") then
        if not originalEffectsCache[obj] then
            originalEffectsCache[obj] = {Enabled = obj.Enabled}
        end
        pcall(function() obj.Enabled = false end)
    end
end

local function toggleEffects()
    effectsEnabled = not effectsEnabled
    if not effectsEnabled then
        local searchTargets = {workspace, Lighting, Camera}
        local count = 0
        for _, parent in ipairs(searchTargets) do
            for _, object in ipairs(parent:GetDescendants()) do
                stripEffects(object)
                count = count + 1
                if count % 150 == 0 then task.wait() end
            end
        end

        dynamicEffectsConnection = game.DescendantAdded:Connect(function(newObject)
            if getgenv().SpotifyCurrentExecutionID ~= UniqueExecutionID then
                if dynamicEffectsConnection then
                    dynamicEffectsConnection:Disconnect()
                    dynamicEffectsConnection = nil
                end
                return
            end
            if not effectsEnabled then stripEffects(newObject) end
        end)

        NoEffectsButton.Text = "EFFECTS: OFF"
        NoEffectsButton.BackgroundColor3 = Color3.fromRGB(30, 215, 96)
        NoEffectsButton.TextColor3 = Color3.fromRGB(0, 0, 0)
    else
        if dynamicEffectsConnection then
            dynamicEffectsConnection:Disconnect()
            dynamicEffectsConnection = nil
        end

        for targetObj, properties in pairs(originalEffectsCache) do
            if typeof(targetObj) == "Instance" and targetObj.Parent then
                pcall(function()
                    targetObj.Enabled = properties.Enabled
                end)
            end
        end
        originalEffectsCache = {}

        NoEffectsButton.Text = "EFFECTS: ON"
        NoEffectsButton.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
        NoEffectsButton.TextColor3 = Color3.fromRGB(255, 255, 255)
    end
